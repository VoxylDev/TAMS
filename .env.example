# =============================================================================
# TAMS Configuration
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env

# --- PostgreSQL ---
TAMS_DB_HOST=localhost
TAMS_DB_PORT=5432
TAMS_DB_NAME=tams
TAMS_DB_USER=tams
TAMS_DB_PASSWORD=
# TAMS_DB_MAX_CONNECTIONS=10

# --- Redis ---
TAMS_REDIS_HOST=localhost
TAMS_REDIS_PORT=6379
# TAMS_REDIS_PASSWORD=
# TAMS_REDIS_PREFIX=tams

# --- LLM Provider (OpenAI-compatible API) ---
# TAMS uses any OpenAI-compatible endpoint for consolidation.
# Set TAMS_LLM_API_KEY and optionally TAMS_LLM_BASE_URL for your provider.

# OpenAI (default — no base URL needed)
TAMS_LLM_API_KEY=sk-...
# TAMS_LLM_FAST_MODEL=gpt-4o-mini
# TAMS_LLM_ABSTRACT_MODEL=gpt-4o-mini

# Anthropic (via OpenAI-compatible endpoint)
# TAMS_LLM_API_KEY=sk-ant-api03-...
# TAMS_LLM_BASE_URL=https://api.anthropic.com/v1/
# TAMS_LLM_FAST_MODEL=claude-haiku-4-5-20251001
# TAMS_LLM_ABSTRACT_MODEL=claude-sonnet-4-5-20250514

# Ollama (local, no key needed)
# TAMS_LLM_API_KEY=ollama
# TAMS_LLM_BASE_URL=http://localhost:11434/v1/
# TAMS_LLM_FAST_MODEL=llama3.2
# TAMS_LLM_ABSTRACT_MODEL=llama3.2

# OpenRouter
# TAMS_LLM_API_KEY=sk-or-...
# TAMS_LLM_BASE_URL=https://openrouter.ai/api/v1/
# TAMS_LLM_FAST_MODEL=openai/gpt-4o-mini
# TAMS_LLM_ABSTRACT_MODEL=anthropic/claude-sonnet-4-5

# Together
# TAMS_LLM_API_KEY=...
# TAMS_LLM_BASE_URL=https://api.together.xyz/v1/
# TAMS_LLM_FAST_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# --- Consolidation ---
# TAMS_LLM_LOW_SIGNAL_THRESHOLD=50    # Min tokens for full consolidation

# --- Short-Term Memory (STM) Buffer ---
# TAMS_STM_MAX_ENTRIES=5               # Max recent conversations in buffer
# TAMS_STM_MAX_PROMPTS=10              # Max user prompts to buffer
# TAMS_STM_MAX_TAIL_CHARS=2000         # Chars per STM entry (~500 tokens)
# TAMS_STM_TTL=7200                    # Buffer TTL in seconds (2 hours)

# --- Server ---
# TAMS_SERVER_PORT=3100
TAMS_LOG_LEVEL=info
